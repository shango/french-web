---
import CorrectionMargin from '../CorrectionMargin.astro'

// A real single-answer noun study card. Static showcase of the app surface.
// state per option: correct | wrong | dim | idle.
type OptState = 'correct' | 'wrong' | 'dim' | 'idle'
interface Opt {
  article: 'le' | 'la'
  word: string
  gloss?: string
  state?: OptState
}
interface Props {
  eyebrow: string
  prompt: string
  options: Opt[]
  audio?: boolean
  tone?: 'correct' | 'wrong'
  nextLabel?: string
}
const { eyebrow, prompt, options, audio = true, tone = 'correct', nextLabel = 'Next' } = Astro.props
---

<div class="card">
  <CorrectionMargin left={30} inset={16} strong={0.45} faint={0.16} />

  <div class="head">
    <div class="eyebrow">{eyebrow}</div>
    <div class="prompt-row">
      <div class="prompt">{prompt}</div>
      {audio && (
        <span class="audio">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4z" /><path d="M15.5 8.5a5 5 0 0 1 0 7" /></svg>Écouter
        </span>
      )}
    </div>
    <div class="rule"></div>
  </div>

  <div class="options">
    {options.map((o) => (
      <div class:list={['opt', `opt--${o.state ?? 'idle'}`]}>
        <span class="dot"></span>
        <span class:list={['art', `art--${o.article}`]}>{o.article}</span>
        <span class="word">{o.word}</span>
        {o.gloss && <span class="gloss">{o.gloss}</span>}
        {o.state === 'correct' && <span class="mark mark--ok" aria-hidden="true">✓</span>}
        {o.state === 'wrong' && <span class="mark mark--no" aria-hidden="true">✕</span>}
      </div>
    ))}
  </div>

  <div class="foot">
    <div class:list={['feedback', `feedback--${tone}`]}><slot name="feedback" /></div>
    <span class="next">{nextLabel}</span>
  </div>
</div>

<style>
  .card {
    width: 384px;
    max-width: 100%;
    position: relative;
    background: var(--paper);
    border: 1px solid var(--hairline-2);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .head {
    padding: 20px 22px 12px 40px;
  }
  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted-2);
  }
  .prompt-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: 9px;
    gap: 10px;
  }
  .prompt {
    font-family: var(--font-serif);
    font-size: 31px;
    color: var(--ink);
    line-height: 1;
  }
  .audio {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--le);
    background: var(--paper-white);
    border: 1.5px solid var(--row-border);
    border-radius: 9px;
    padding: 7px 11px;
    flex: none;
  }
  .rule {
    height: 1.5px;
    background: var(--rule-violet);
    margin-top: 13px;
  }

  .options {
    padding: 4px 22px 14px 40px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .opt {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 12px 16px;
    border-radius: 11px;
    border: 1.5px solid var(--row-border);
    background: var(--paper-white);
    min-height: 52px;
  }
  .opt--dim {
    opacity: 0.42;
  }
  .opt--correct {
    border-color: var(--green-border);
    background: var(--green-bg);
  }
  .opt--wrong {
    border-color: var(--wrong-border);
    background: var(--wrong-bg);
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--rule-violet);
    flex: none;
  }
  .art {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
  }
  .art--le {
    color: var(--le);
  }
  .art--la {
    color: var(--la);
  }
  .word {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--ink);
  }
  .gloss {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-muted);
  }
  .mark {
    margin-left: auto;
    font-size: 17px;
  }
  .mark--ok {
    color: var(--green);
  }
  .mark--no {
    color: var(--red);
  }

  .foot {
    border-top: 1px solid var(--hairline);
    padding: 15px 22px 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .feedback {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.35;
  }
  .feedback--correct {
    color: var(--green);
  }
  .feedback--wrong {
    color: var(--ink-soft);
  }
  .next {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--paper);
    background: var(--ink);
    border-radius: 9px;
    padding: 10px 20px;
    flex: none;
  }
</style>
