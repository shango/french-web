---
// Le Cahier default profile avatar (shared with the app). Paper disc + single violet
// ruling ring; monogram once a name exists, else a hand-drawn ink portrait. Accent is
// assigned deterministically from a stable key so a user's mark never changes.
interface Props {
  name?: string
  userId?: string
  size?: number
}
const { name, userId, size = 48 } = Astro.props

const ACCENTS = ['#1e2a44', '#435e7e', '#8b5a78', '#b08a2e'] // ink, slate, plum, gold-label
function pickAccent(key: string): string {
  let h = 0
  for (const c of String(key)) h = (h * 31 + c.charCodeAt(0)) >>> 0
  return ACCENTS[h % ACCENTS.length]
}
function initials(n: string | undefined): string {
  const p = (n ?? '').trim().split(/\s+/).filter(Boolean)
  if (!p.length) return ''
  return (p[0][0] + (p.length > 1 ? p[p.length - 1][0] : '')).toUpperCase()
}

const accent = pickAccent(userId ?? name ?? 'anon')
const ring = size >= 48 ? 1.5 : size >= 32 ? 1.25 : 1
const showRule = size >= 40
const label = name || 'Profile'
const mono = size < 40 || name ? initials(name) : '' // prefer monogram below ~40px
---

<div
  class="avatar"
  role="img"
  aria-label={label}
  style={`width:${size}px; height:${size}px; box-shadow: inset 0 0 0 ${ring}px var(--rule-violet);`}
>
  {mono ? (
    <>
      <span style={`font-family: var(--font-serif); font-weight:500; font-size:${size * 0.42}px; color:${accent}; line-height:1;`}>{mono}</span>
      {showRule && (
        <span style={`width:${size * 0.34}px; height:1.5px; background: var(--rule-violet); margin-top:${size * 0.07}px; border-radius:1px;`}></span>
      )}
    </>
  ) : (
    <svg width={size} height={size} viewBox="0 0 48 48" fill="none" aria-hidden="true">
      <circle cx="24" cy="18" r="7.2" stroke={accent} stroke-width="2.2" />
      <path d="M12 38C12 30.5 17.4 26 24 26C30.6 26 36 30.5 36 38" stroke={accent} stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )}
</div>

<style>
  .avatar {
    border-radius: 50%;
    background: var(--paper);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
</style>
