---
import BaseLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import Button from '../components/Button.astro'
import Seal from '../components/Seal.astro'
import RuleLine from '../components/RuleLine.astro'
import NounCard from '../components/showcase/NounCard.astro'
import Dashboard from '../components/showcase/Dashboard.astro'
import Certificate from '../components/showcase/Certificate.astro'
import { START_HREF } from '../consts'

const chips = ['table', 'nation', 'impossible', 'important', 'théâtre', 'nature']
const dashRows = [
  { name: 'Verbs', sub: 'everyday actions', known: 42, total: 60 },
  { name: 'Nouns', sub: 'Restaurant · Café · Taxi…', known: 55, total: 150 },
  { name: 'Cognates', sub: 'mastered, a full deck', subTone: 'gold' as const, known: 180, total: 180, sealed: true },
]
---

<BaseLayout>
  {/* ===================== HERO (word on the ruled line) ===================== */}
  <Section py="70px" class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">French vocabulary, written by hand</div>
        <h1 class="hero-h1">A real base in French, then we wave you off.</h1>
        <p class="hero-sub">Learn the ~400 words that actually carry a conversation. When you have them, Le Cahier hands you a certificate, your word list, and where to go next, and lets you leave. That's the whole point.</p>
        <div class="hero-cta">
          <Button href={START_HREF} variant="primary" size="md">Start free</Button>
          <Button href="/how-it-works" variant="text">See how it works</Button>
        </div>
        <div class="fineprint">No card to start · cancel anytime · export your words whenever you leave</div>
      </div>

      <div class="hero-panel-wrap">
        <div class="panel">
          <span class="pm pm--a" aria-hidden="true"></span>
          <span class="pm pm--b" aria-hidden="true"></span>
          <div class="panel-eyebrow">Leçon 1 · le premier mot</div>
          <div class="word-wrap">
            <span class="word">commencer</span>
          </div>
          <div class="word-gloss">
            <span class="pos">verbe</span>
            <span class="en">· to begin</span>
          </div>
          <div class="panel-foot">
            <Seal size={44} label="N1" />
            <div class="goal">Every word you learn moves you toward one honest goal, <span>400 words and a finished primer.</span></div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  {/* ===================== COGNATE WINDFALL ===================== */}
  <Section band="windfall" py="64px">
    <div class="windfall-grid">
      <div class="wf-copy">
        <div class="eyebrow eyebrow--gold">The cognate windfall</div>
        <h2 class="wf-h2">You already know<br />~180 French words.</h2>
        <p class="wf-body">About a third of English comes from French. We start you there, on the ground you already stand on, so your first session is a win, not a wall. Then we teach you to tell the true friends from the false ones.</p>
      </div>
      <div class="wf-cardwrap">
        <div class="wf-card">
          <div class="wf-card-eyebrow">Free words, on us</div>
          <div class="chips">
            {chips.map((c) => <span class="chip">{c}</span>)}
          </div>
          <div class="wf-divider"></div>
          <div class="false-friend">
            <span class="ff-word">librairie</span>
            <span class="ff-gloss">is a <i>bookshop</i>, not a library. We teach the false friends too.</span>
          </div>
        </div>
      </div>
    </div>
  </Section>

  {/* ===================== REAL SURFACES ===================== */}
  <Section py="76px">
    <div class="surfaces-head">
      <div class="eyebrow">The actual app</div>
      <h2 class="sec-h2">Tap to answer. Get a gentle correction. Move on.</h2>
      <p class="sec-body">No hearts, no streak to protect, no points. A wrong turn is a note in the margin, not a buzzer. Here's a real card and a real dashboard, nothing staged.</p>
    </div>
    <div class="surfaces-row">
      <NounCard
        eyebrow="Nouns · tap the French"
        prompt="the house"
        tone="correct"
        options={[
          { article: 'la', word: 'maison', gloss: 'house', state: 'correct' },
          { article: 'la', word: 'fenêtre', state: 'dim' },
          { article: 'le', word: 'jardin', state: 'dim' },
        ]}
      >
        <Fragment slot="feedback">✓ Correct, <i>la maison</i></Fragment>
      </NounCard>

      <div class="dash-wrap">
        <Dashboard
          rows={dashRows}
          gradText="277 / 400 words toward your certificate"
          note="We count words you actually know, never a vague “% of French.” Honest numbers are the only kind worth showing."
        />
      </div>
    </div>
  </Section>

  {/* ===================== GRADUATION PAYOFF ===================== */}
  <Section py="76px">
    <div class="grad-card">
      <div class="grad-copy">
        <div class="eyebrow eyebrow--gold">The finish line is the feature</div>
        <h2 class="sec-h2">You'll finish. Here's your proof.</h2>
        <p class="sec-body sec-body--narrow">At 400 words the primer is done. You leave with a certificate, your full word list exported to CSV or Anki, and honest recommendations for what to study next, grammar, graded readers, a tutor.</p>
        <ul class="checklist">
          <li><span class="ck">✓</span> A Level-1 certificate with your name on it</li>
          <li><span class="ck">✓</span> Your words, exported, CSV &amp; Anki</li>
          <li><span class="ck">✓</span> Where to go next, no upsell to us</li>
        </ul>
      </div>
      <div class="cert-wrap">
        <Certificate />
      </div>
    </div>
  </Section>

  {/* ===================== WHO IT'S FOR / ISN'T ===================== */}
  <Section band="desk" py="68px">
    <div class="who-head">
      <div class="eyebrow">Honest about the fit</div>
      <h2 class="sec-h2">Who Le Cahier is, and isn't, for</h2>
    </div>
    <div class="who-grid">
      <div class="who-card">
        <div class="who-eyebrow who-eyebrow--good">A good fit if you…</div>
        <ul class="who-list">
          <li><span class="wk wk--good">✓</span> Are starting from zero and want a confident base before grammar</li>
          <li><span class="wk wk--good">✓</span> Remember some school French and want to prove it and skip ahead</li>
          <li><span class="wk wk--good">✓</span> Want a real finish line, not a subscription that never ends</li>
        </ul>
      </div>
      <div class="who-card">
        <div class="who-eyebrow who-eyebrow--bad">Not the right tool if you…</div>
        <ul class="who-list who-list--muted">
          <li><span class="wk wk--bad">✕</span> Need full grammar and conjugation drills right now</li>
          <li><span class="wk wk--bad">✕</span> Are already conversational and want speaking practice</li>
          <li><span class="wk wk--bad">✕</span> Want a game with points and leaderboards to keep you hooked</li>
        </ul>
      </div>
    </div>
    <p class="who-foot">Not sure? The first words are free, try a session and see if the pace fits. Getting the wrong person to sign up helps no one.</p>
  </Section>

  {/* ===================== CLOSING CTA ===================== */}
  <Section py="84px" center>
    <div class="rule-center"><RuleLine width="60px" /></div>
    <h2 class="closing-h2">Start with the word you already know: <i>commencer.</i></h2>
    <p class="closing-body">Free to begin, no card required. Learn a base worth having, then take your words and go.</p>
    <div class="closing-cta">
      <Button href={START_HREF} variant="primary" size="lg">Start free</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  /* Shared small type */
  .eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8c8776;
  }
  .eyebrow--gold {
    color: var(--gold-label);
  }
  .sec-h2 {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    line-height: 1.14;
    margin-top: 12px;
  }
  .sec-body {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-top: 16px;
  }
  .sec-body--narrow {
    max-width: 420px;
  }

  /* ---------- Hero ---------- */
  .hero-grid {
    display: flex;
    gap: 60px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-copy {
    flex: 1 1 380px;
    min-width: 320px;
  }
  .hero-h1 {
    font-size: var(--fs-hero-h1);
    line-height: 1.1;
    margin-top: 18px;
  }
  .hero-sub {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 480px;
    margin-top: 20px;
  }
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 30px;
    flex-wrap: wrap;
  }
  .fineprint {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    margin-top: 18px;
  }
  .hero-panel-wrap {
    flex: 1 1 400px;
    min-width: 320px;
  }
  .panel {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--hairline-2);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-hero);
    padding: 46px 44px 40px 58px;
    overflow: hidden;
  }
  .pm {
    position: absolute;
    top: 20px;
    bottom: 20px;
    width: 1.5px;
    background: var(--red);
  }
  .pm--a {
    left: 34px;
    opacity: 0.4;
  }
  .pm--b {
    left: 38px;
    opacity: 0.14;
  }
  .panel-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted-2);
  }
  .word-wrap {
    margin-top: 26px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--rule-violet);
  }
  .word {
    font-family: var(--font-serif);
    font-size: var(--fs-hero-word);
    line-height: 1;
    color: var(--ink);
  }
  .word-gloss {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 12px;
  }
  .pos {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    color: var(--la);
  }
  .en {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink-soft);
  }
  .panel-foot {
    margin-top: 30px;
    border-top: 1px solid var(--hairline);
    padding-top: 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .goal {
    font-family: var(--font-sans);
    font-size: 13.5px;
    color: var(--ink-muted);
    line-height: 1.5;
  }
  .goal span {
    color: var(--ink);
  }

  /* ---------- Windfall ---------- */
  .windfall-grid {
    display: flex;
    gap: 56px;
    align-items: center;
    flex-wrap: wrap;
  }
  .wf-copy {
    flex: 1 1 360px;
    min-width: 300px;
  }
  .wf-h2 {
    font-family: var(--font-serif);
    font-size: 40px;
    line-height: 1.12;
    margin-top: 14px;
  }
  .wf-body {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 440px;
    margin-top: 18px;
  }
  .wf-cardwrap {
    flex: 1 1 380px;
    min-width: 300px;
  }
  .wf-card {
    background: var(--paper);
    border: 1px solid var(--hairline-2);
    border-radius: var(--radius-card);
    box-shadow: 0 16px 40px -28px rgba(30, 42, 68, 0.5);
    padding: 26px 28px;
  }
  .wf-card-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted-2);
    margin-bottom: 16px;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .chip {
    font-family: var(--font-serif);
    font-size: 19px;
    color: var(--ink);
    background: var(--locked-bg);
    border: 1px solid var(--windfall-border);
    border-radius: 9px;
    padding: 7px 14px;
  }
  .wf-divider {
    height: 1px;
    background: var(--hairline);
    margin: 20px 0;
  }
  .false-friend {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ff-word {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--la);
    text-decoration: line-through;
    text-decoration-color: var(--wrong-border);
  }
  .ff-gloss {
    font-family: var(--font-sans);
    font-size: 13.5px;
    color: var(--ink-muted);
  }
  .ff-gloss i {
    font-family: var(--font-serif);
  }

  /* ---------- Real surfaces ---------- */
  .surfaces-head {
    max-width: 560px;
  }
  .surfaces-row {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-top: 44px;
  }
  .dash-wrap {
    flex: 1 1 460px;
    min-width: 320px;
  }

  /* ---------- Graduation ---------- */
  .grad-card {
    background: var(--paper);
    border: 1px solid var(--hairline-2);
    border-radius: var(--radius-card-lg);
    box-shadow: 0 24px 60px -34px rgba(30, 42, 68, 0.45);
    padding: 48px;
    display: flex;
    gap: 52px;
    align-items: center;
    flex-wrap: wrap;
  }
  .grad-copy {
    flex: 1 1 340px;
    min-width: 300px;
  }
  .checklist {
    list-style: none;
    padding: 0;
    margin: 24px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .checklist li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
  }
  .ck {
    color: var(--green);
    font-size: 16px;
  }
  .cert-wrap {
    flex: 1 1 360px;
    min-width: 300px;
  }

  /* ---------- Who it's for ---------- */
  .who-head {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .who-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }
  .who-card {
    background: var(--paper);
    border: 1px solid var(--hairline-2);
    border-radius: var(--radius-card);
    padding: 28px 30px;
  }
  .who-eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .who-eyebrow--good {
    color: var(--green);
  }
  .who-eyebrow--bad {
    color: var(--red);
  }
  .who-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .who-list li {
    display: flex;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink);
  }
  .who-list--muted li {
    color: var(--ink-soft);
  }
  .wk {
    flex: none;
  }
  .wk--good {
    color: var(--green);
  }
  .wk--bad {
    color: var(--red);
  }
  .who-foot {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    text-align: center;
    margin: 28px auto 0;
    max-width: 520px;
    line-height: 1.6;
  }

  /* ---------- Closing ---------- */
  .rule-center {
    display: flex;
    justify-content: center;
  }
  .closing-h2 {
    font-family: var(--font-serif);
    font-size: 44px;
    line-height: 1.12;
    margin: 26px auto 0;
    max-width: 620px;
  }
  .closing-body {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 460px;
    margin: 18px auto 0;
  }
  .closing-cta {
    margin-top: 30px;
  }

  @media (max-width: 640px) {
    .hero-h1 {
      font-size: 40px;
    }
    .wf-h2 {
      font-size: 32px;
    }
    .closing-h2 {
      font-size: 34px;
    }
    .grad-card {
      padding: 32px 24px;
    }
    .panel {
      padding: 34px 26px 30px 40px;
    }
    .word {
      font-size: 44px;
    }
  }
</style>
