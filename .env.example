# Le Cahier marketing site environment.
# Copy to .env (or .env.local) and fill in. Astro exposes PUBLIC_* vars to the client;
# non-prefixed vars stay server-only.

# Clerk (same instance as the app, so the account is portable across web/iOS).
# Clerk Dashboard -> API Keys. Publishable key is public (safe in the browser).
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Post-signup redirect target: the web app (no trailing slash).
# Example: https://app.lecahier.app
PUBLIC_APP_URL=http://localhost:5173

# Privacy-first analytics token (Cloudflare Web Analytics). Optional; leave blank to disable.
PUBLIC_CF_ANALYTICS_TOKEN=
