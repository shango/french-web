# Cloudflare Pages headers. Long-lived immutable caching for content-hashed and
# self-hosted static assets; everything else falls back to the default.

# Astro emits content-hashed filenames under /_astro - safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted subset fonts never change under the same filename.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Baseline security headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
